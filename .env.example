# Anthropic — required for Copilot, finding narration, remediation drafts
ANTHROPIC_API_KEY=sk-ant-...

# Coral — local-first; isolate the workspace to this project
CORAL_CONFIG_DIR=./.coral-workspace

# Quartermaster local state (SQLite)
QM_STATE_DB=./.qm-state.db

# Source tokens (paste yours; never commit)
DEEL_API_TOKEN=
OKTA_API_TOKEN=
GITHUB_TOKEN=
SLACK_BOT_TOKEN=
STRIPE_SECRET_KEY=

# Demo mode — swaps live Coral calls for canned JSON
QM_FIXTURES=on

# Continuous Mode default tick (seconds)
QM_CONTINUOUS_INTERVAL=30
